// =============================================================================
// Nextflow Configuration — 22q13 WGCNA Pipeline
// =============================================================================

manifest {
    name            = '22q13_WGCNA'
    author          = 'Snehal Shah'
    description     = 'Weighted Gene Co-expression Network Analysis for 22q13 / Phelan-McDermid Syndrome'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

// ---------------------------------------------------------------------------
// Default parameters (override via --param_name on the command line or via
// a params YAML file: nextflow run main.nf -params-file conf/params.yaml)
// ---------------------------------------------------------------------------
params {
    // Input data
    expression   = null   // Path to combined gene expression CSV (cols 1-10: annotation, 11-534: BrainSpan)

    // Output
    outdir          = "${projectDir}/../results"

    // Pipeline control
    skip_cytoscape  = true   // Set false only if Cytoscape desktop is running
                              // and RCy3 can connect to it

    // Help flag
    help            = false
}

// ---------------------------------------------------------------------------
// Docker profile (recommended for reproducibility)
// ---------------------------------------------------------------------------
profiles {

    docker {
        docker.enabled         = true
        singularity.enabled    = false
        process.container      = '22q13-wgcna:latest'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process.container      = '22q13-wgcna:latest'
    }

    // Local execution without a container (requires all R packages installed)
    local {
        docker.enabled      = false
        singularity.enabled = false
    }

    // HPC / SLURM template
    slurm {
        process.executor = 'slurm'
        process.queue    = 'general'
        docker.enabled   = false
        singularity.enabled = true
        singularity.autoMounts = true
    }
}

// ---------------------------------------------------------------------------
// Default process resource allocation
// ---------------------------------------------------------------------------
process {
    container     = '22q13-wgcna:latest'
    // Retry on OOM (exit 137 = Linux OOM kill) or SLURM memory-exceeded (exit 140);
    // stop immediately on all other non-zero exit codes so real errors surface fast.
    errorStrategy = { task.exitStatus in [130, 137, 140, 143] ? 'retry' : 'finish' }
    maxRetries    = 1

    withLabel: 'small' {
        cpus   = 2
        memory = '8 GB'
        time   = '1 h'
    }

    withLabel: 'medium' {
        cpus   = 4
        memory = '16 GB'
        time   = '4 h'
    }

    // WGCNA network construction is memory-intensive.
    // On an OOM retry, memory doubles (24 GB → 48 GB) and wall-time extends
    // proportionally so the job is not killed by the scheduler for time either.
    withLabel: 'high_mem' {
        cpus       = 4
        memory     = { 24.GB * task.attempt }
        time       = { 12.h  * task.attempt }
        maxRetries = 2
    }
}

// ---------------------------------------------------------------------------
// Execution reports
// ---------------------------------------------------------------------------
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_timeline.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_dag.html"
    overwrite = true
}
